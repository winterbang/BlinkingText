<page-meta root-font-size="system" page-style="overflow: hidden;" />
<view class="container">
  <!-- 上半部分：画布区域（固定高度） -->
  <view class="preview-section">
    <view class="canvas-container">
      <view class="canvas-wrapper">
      <canvas
        type="2d"
        id="previewCanvas"
        class="preview-canvas"
      />
      <view class="canvas-loading" wx:if="{{isGenerating}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">生成中...</text>
      </view>
    </view>
    </view>

    <view class="canvas-actions">
      <view class="action-btn" bindtap="togglePlay">
        <image class="action-icon-img" wx:if="{{isPlaying}}" src="data:image/svg+xml;base64," mode="aspectFit"/>
        <image class="action-icon-img" wx:else src="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCIgdmlld0JveD0iMCAwIDI0IDI0IiBmaWxsPSJub25lIiBzdHJva2U9IiMzMzMiIHN0cm9rZS13aWR0aD0iMiIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIiBzdHJva2UtbGluZWpvaW49InJvdW5kIj48cG9seWdvbiBwb2ludHM9IjUgMyAxOSAxMiA1IDIxIDUgMyIvPjwvc3ZnPg==" mode="aspectFit"/>
      </view>
      <view class="action-btn" bindtap="resetCanvas">
        <image class="action-icon-img" src="data:image/svg+xml;base64," mode="aspectFit"/>
      </view>
    </view>
  </view>

  <!-- 下半部分：Tabs 操作区域 -->
  <view class="tabs-section">
    <!-- Tabs 导航 -->
    <view class="tabs-header">
      <view
        class="tab-item {{activeTab === 'text' ? 'active' : ''}}"
        data-tab="text"
        bindtap="switchTab"
      >
        <image class="tab-icon" src="data:image/svg+xml;base64," mode="aspectFit"/>
        <text class="tab-text">文字</text>
      </view>
      <view
        class="tab-item {{activeTab === 'style' ? 'active' : ''}}"
        data-tab="style"
        bindtap="switchTab"
      >
        <image class="tab-icon" src="data:image/svg+xml;base64," mode="aspectFit"/>
        <text class="tab-text">样式</text>
      </view>
      <view
        class="tab-item {{activeTab === 'effect' ? 'active' : ''}}"
        data-tab="effect"
        bindtap="switchTab"
      >
        <image class="tab-icon" src="data:image/svg+xml;base64," mode="aspectFit"/>
        <text class="tab-text">动效</text>
      </view>
      <view
        class="tab-item {{activeTab === 'setting' ? 'active' : ''}}"
        data-tab="setting"
        bindtap="switchTab"
      >
        <image class="tab-icon" src="data:image/svg+xml;base64," mode="aspectFit"/>
        <text class="tab-text">设置</text>
      </view>
    </view>

    <!-- Tabs 内容区 -->
    <view class="tabs-content">
      <!-- Tab 1: 文字 -->
      <scroll-view
        class="tab-panel {{activeTab === 'text' ? 'show' : 'hide'}}"
        scroll-y
        enhanced
        show-scrollbar
      >
        <view class="panel-inner">
          <!-- 文字输入 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">文字内容</text>
              <text class="word-count">{{text.length}}/20</text>
            </view>
            <textarea
              class="text-input"
              placeholder="请输入文字内容，换行请输入回车"
              maxlength="20"
              auto-height
              value="{{text}}"
              bindinput="onTextInput"
            />
          </view>

          <!-- 快捷文字 -->
          <view class="section" wx:if="{{!text}}">
            <view class="section-header">
              <text class="section-title">快捷输入</text>
            </view>
            <view class="quick-texts">
              <view
                class="quick-tag"
                wx:for="{{quickTexts}}"
                wx:key="*this"
                bindtap="setQuickText"
                data-text="{{item}}"
              >
                {{item}}
              </view>
            </view>
          </view>

          <!-- 字体选择 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">字体</text>
            </view>
            <view class="font-list">
              <view
                class="font-item {{fontFamily === item.value ? 'active' : ''}}"
                wx:for="{{fontFamilies}}"
                wx:key="value"
                data-value="{{item.value}}"
                bindtap="selectFontFamily"
              >
                <text class="font-label" style="font-family: {{item.value}};">{{item.label}}</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- Tab 2: 样式 -->
      <scroll-view
        class="tab-panel {{activeTab === 'style' ? 'show' : 'hide'}}"
        scroll-y
        enhanced
        show-scrollbar
      >
        <view class="panel-inner">
          <!-- 字号大小 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">字号大小</text>
              <text class="section-value">{{fontSize}}px</text>
            </view>
            <slider
              class="section-slider"
              min="24"
              max="120"
              value="{{fontSize}}"
              block-size="28"
              activeColor="#07c160"
              backgroundColor="#e5e5e5"
              bindchange="onFontSizeChange"
            />
          </view>

          <!-- 文字颜色 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">文字颜色</text>
            </view>
            <view class="color-grid">
              <view
                class="color-block {{color === item ? 'active' : ''}}"
                wx:for="{{presetColors}}"
                wx:key="*this"
                style="background: {{item}}"
                data-color="{{item}}"
                bindtap="selectColor"
              />
              <view class="color-block custom" bindtap="openColorPicker">
                <text>+</text>
              </view>
            </view>
          </view>

          <!-- 加粗 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">文字加粗</text>
              <switch checked="{{isBold}}" bindchange="toggleBold" color="#07c160"/>
            </view>
          </view>

          <!-- 文字描边 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">描边颜色</text>
            </view>
            <view class="color-grid">
              <view
                class="color-block {{strokeColor === item ? 'active' : ''}}"
                wx:for="{{presetColors}}"
                wx:key="*this"
                style="background: {{item}}"
                data-color="{{item}}"
                bindtap="selectStrokeColor"
              />
              <view
                class="color-block {{strokeColor === '' ? 'active' : ''}} transparent"
                data-color=""
                bindtap="selectStrokeColor"
              >
                <text class="transparent-text">无</text>
              </view>
            </view>
          </view>

          <view class="section" wx:if="{{strokeColor}}">
            <view class="section-header">
              <text class="section-title">描边宽度</text>
              <text class="section-value">{{strokeWidth}}px</text>
            </view>
            <slider
              class="section-slider"
              min="1"
              max="10"
              value="{{strokeWidth}}"
              block-size="28"
              activeColor="#07c160"
              backgroundColor="#e5e5e5"
              bindchange="onStrokeWidthChange"
            />
          </view>

          <!-- 对齐方式 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">对齐方式</text>
            </view>
            <view class="align-list">
              <view
                class="align-item {{textAlign === 'left' ? 'active' : ''}}"
                data-align="left"
                bindtap="selectTextAlign"
              >
                <image class="align-icon" src="data:image/svg+xml;base64," mode="aspectFit"/>
                <text class="align-label">左对齐</text>
              </view>
              <view
                class="align-item {{textAlign === 'center' ? 'active' : ''}}"
                data-align="center"
                bindtap="selectTextAlign"
              >
                <image class="align-icon" src="data:image/svg+xml;base64," mode="aspectFit"/>
                <text class="align-label">居中</text>
              </view>
              <view
                class="align-item {{textAlign === 'right' ? 'active' : ''}}"
                data-align="right"
                bindtap="selectTextAlign"
              >
                <image class="align-icon" src="data:image/svg+xml;base64," mode="aspectFit"/>
                <text class="align-label">右对齐</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- Tab 3: 动效 -->
      <scroll-view
        class="tab-panel {{activeTab === 'effect' ? 'show' : 'hide'}}"
        scroll-y
        enhanced
        show-scrollbar
      >
        <view class="panel-inner">
          <!-- 特效开关 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">动画特效</text>
              <switch checked="{{enableEffects}}" bindchange="toggleEffects" color="#07c160"/>
            </view>
            <text class="section-desc">开启后可以使用动画动效</text>
          </view>

          <!-- 动画速度 -->
          <view class="section" wx:if="{{enableEffects}}">
            <view class="section-header">
              <text class="section-title">动画速度</text>
              <text class="section-value">{{speed}}x</text>
            </view>
            <slider
              class="section-slider"
              min="0.25"
              max="3"
              step="0.25"
              value="{{speed}}"
              block-size="28"
              activeColor="#07c160"
              backgroundColor="#e5e5e5"
              bindchange="onSpeedChange"
            />
          </view>

          <!-- 动效列表 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">选择动效</text>
            </view>
            <view class="template-grid">
              <view
                class="template-card {{selectedTemplate === item.id ? 'active' : ''}} {{!enableEffects ? 'disabled' : ''}}"
                wx:for="{{templates}}"
                wx:key="id"
                data-id="{{item.id}}"
                bindtap="selectTemplate"
              >
                <view class="template-icon-box" style="background: {{item.previewColor || '#f5f5f5'}}">
                  <text class="template-icon">{{item.icon}}</text>
                </view>
                <text class="template-name">{{item.name}}</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- Tab 4: 设置 -->
      <scroll-view
        class="tab-panel {{activeTab === 'setting' ? 'show' : 'hide'}}"
        scroll-y
        enhanced
        show-scrollbar
      >
        <view class="panel-inner">
          <!-- 背景颜色 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">背景颜色</text>
            </view>
            <view class="color-grid">
              <view
                class="color-block {{bgColor === item ? 'active' : ''}} transparent"
                wx:for="{{bgColors}}"
                wx:key="*this"
                style="background: {{item}}"
                data-color="{{item}}"
                bindtap="selectBgColor"
              >
                <text wx:if="{{item === 'transparent'}}" class="transparent-text">透明</text>
              </view>
            </view>
          </view>

          <!-- 画布尺寸 -->
          <view class="section">
            <view class="section-header">
              <text class="section-title">画布尺寸</text>
            </view>
            <view class="size-grid">
              <view
                class="size-block {{canvasSize === item.value ? 'active' : ''}}"
                wx:for="{{canvasSizes}}"
                wx:key="value"
                data-value="{{item.value}}"
                bindtap="selectCanvasSize"
              >
                <text class="size-label">{{item.label}}</text>
                <text class="size-value">{{item.value}}px</text>
              </view>
            </view>
          </view>

          <!-- 导出按钮 -->
          <view class="section export-section">
            <button
              class="btn-export {{isGenerating ? 'loading' : ''}}"
              bindtap="exportGif"
              disabled="{{isGenerating || !text}}"
            >
              <text wx:if="{{!isGenerating}}">生成 GIF</text>
              <text wx:else>生成中 {{progress}}%</text>
            </button>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 颜色选择器弹窗 -->
  <view class="modal-mask" wx:if="{{showColorPicker}}" bindtap="closeColorPicker"></view>
  <view class="modal-content color-picker-modal" wx:if="{{showColorPicker}}">
    <view class="modal-header">
      <text class="modal-title">选择颜色</text>
      <text class="modal-close" bindtap="closeColorPicker">×</text>
    </view>
    <view class="modal-body">
      <!-- 颜色预览和HEX输入 -->
      <view class="color-preview-section">
        <view class="color-preview-box" style="background-color: {{previewColor}};"></view>
        <view class="color-value-section">
          <text class="color-label">HEX</text>
          <input
            class="color-hex-input"
            type="text"
            maxlength="7"
            value="{{previewColor}}"
            bindinput="onHexInput"
            bindblur="onHexBlur"
          />
        </view>
      </view>

      <!-- 色相滑块 -->
      <view class="hue-slider-section">
        <text class="slider-label">滑动选择颜色</text>
        <view class="hue-slider-wrapper">
          <view class="hue-gradient"></view>
          <slider
            class="hue-slider"
            min="0"
            max="360"
            value="{{hueValue}}"
            block-size="28"
            backgroundColor="transparent"
            activeColor="transparent"
            bindchange="onHueChange"
            bindchanging="onHueChange"
          />
        </view>
        <text class="hue-value">色相: {{hueValue}}°</text>
      </view>

      <!-- 操作按钮 -->
      <view class="picker-actions">
        <button class="btn-cancel" bindtap="closeColorPicker">取消</button>
        <button class="btn-confirm" bindtap="confirmColorPicker" style="background-color: {{previewColor}};">确定</button>
      </view>
    </view>
  </view>
</view>