.container {
  min-height: 100vh;
  padding-bottom: 48rpx;
}

/* Banner */
.banner {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  padding: 64rpx 48rpx;
  color: #ffffff;
}

.banner-title {
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.banner-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

/* Feature Grid */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 32rpx;
  margin-top: 24rpx;
}

.feature-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  min-height: 200rpx;
}

.feature-card:active {
  transform: scale(0.96);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.lucide-icon {
  width: 48rpx;
  height: 48rpx;
}

.lucide-icon-large {
  width: 96rpx;
  height: 96rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
}

.section-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.action-icon-small {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.4);
}

.text-icon {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  color: #ffffff;
}

.gif-icon {
  background: linear-gradient(135deg, #3b82f6 0%, #6366f1 100%);
  color: #ffffff;
}

.video-icon {
  background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
  color: #ffffff;
}

.template-icon {
  background: linear-gradient(135deg, #ec4899 0%, #f43f5e 100%);
  color: #ffffff;
}

.feature-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #000000;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.4);
}

/* Section */
.section {
  margin-top: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
}

.section-more {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.4);
}

/* Works List */
.works-list {
  padding: 0 32rpx;
}

.work-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.work-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.work-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.work-text {
  font-size: 30rpx;
  color: #000000;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.work-date {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.4);
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 48rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.6);
  margin-bottom: 8rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.4);
}

/* Footer Tips */
.footer-tips {
  text-align: center;
  padding: 48rpx 32rpx;
}

.tips-text {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.3);
}
